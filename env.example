// frontend/src/hooks/useMetaFeed.js
import { useState, useEffect, useCallback } from "react";
import {
  getCurrentUser,
  getCombinedFeed,
  getFacebookPosts,
  getInstagramPosts,
} from "../utils/api";

export function useMetaFeed() {
  const [user, setUser] = useState(null);
  const [posts, setPosts] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [filter, setFilter] = useState("all"); // "all" | "facebook" | "instagram"

  const loadUser = useCallback(async () => {
    try {
      const data = await getCurrentUser();
      setUser(data);
    } catch (err) {
      setError(err.message);
    }
  }, []);

  const loadFeed = useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const data = await getCombinedFeed(50);
      setPosts(data.posts);
    } catch (err) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  }, []);

  const loadPlatformPosts = useCallback(async (platform, accountId) => {
    setLoading(true);
    setError(null);
    try {
      const fetcher = platform === "facebook" ? getFacebookPosts : getInstagramPosts;
      const data = await fetcher(accountId, 25);
      setPosts(data.posts.map((p) => ({ ...p, platform })));
    } catch (err) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    loadUser();
    loadFeed();
  }, [loadUser, loadFeed]);

  const filteredPosts =
    filter === "all" ? posts : posts.filter((p) => p.platform === filter);

  return {
    user,
    posts: filteredPosts,
    allPosts: posts,
    loading,
    error,
    filter,
    setFilter,
    refresh: loadFeed,
    loadPlatformPosts,
  };
}
